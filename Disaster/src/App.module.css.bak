/* App layout */
.app {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--bg-base);
}

.body {
  display: flex;
  flex: 1;
  overflow: hidden;
}

.main {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── Reports Tab ── */
.reportsPage {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
}

.pageTitle {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--text-muted);
  margin-bottom: 14px;
}

.reportsGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 10px;
}

.reportCard {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 12px 14px;
  border-left: 3px solid var(--c);
  transition: border-color var(--transition);
  animation: fadeIn 0.25s ease both;
}

.reportCard:hover { border-color: var(--c); }

.cardTop {
  display: flex;
  align-items: center;
  gap: 7px;
  margin-bottom: 6px;
  flex-wrap: wrap;
}

.cardRank {
  font-size: 10px;
  color: var(--text-muted);
  font-weight: 700;
}

.cardType {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 0.05em;
}

.cardBadge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  padding: 2px 7px;
  border-radius: 3px;
  background: rgba(255,255,255,0.05);
}

.cardScore {
  font-size: 10px;
  font-weight: 700;
  margin-left: auto;
  letter-spacing: 0.06em;
}

.cardLoc {
  font-size: 12px;
  color: var(--text-secondary);
  margin-bottom: 5px;
}

.cardMeta {
  display: flex;
  gap: 6px;
  font-size: 10px;
  color: var(--text-muted);
  margin-bottom: 6px;
  flex-wrap: wrap;
}

.cardDesc {
  font-size: 11px;
  color: var(--text-muted);
  font-style: italic;
  margin-bottom: 8px;
  line-height: 1.5;
}

.cardBar {
  height: 2px;
  background: var(--border);
  border-radius: 1px;
  margin-bottom: 10px;
  overflow: hidden;
}

.cardBarFill {
  height: 100%;
  border-radius: 1px;
  opacity: 0.8;
}

.cardResolve {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--text-muted);
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  transition: all var(--transition);
  font-family: var(--font-mono);
}

.cardResolve:hover {
  background: var(--green-dim);
  border-color: var(--green);
  color: var(--green);
}

/* ── Analytics Tab ── */
.analyticsPage {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
}

.analytics { display: flex; flex-direction: column; gap: 16px; }

.analyticsTitle {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.14em;
  color: var(--text-muted);
}

.analyticsGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 8px;
}

.analyticCard {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 12px 14px;
  position: relative;
  overflow: hidden;
}

.analyticCard::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: var(--c);
}

.analyticVal {
  font-family: var(--font-display);
  font-size: 28px;
  font-weight: 800;
  color: var(--c);
  line-height: 1;
  margin-bottom: 4px;
}

.analyticLabel {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: var(--text-muted);
}

.chartsRow {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.chartBox {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 14px;
}

.chartTitle {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 12px;
}

.barChart { display: flex; flex-direction: column; gap: 10px; }

.barRow {
  display: flex;
  align-items: center;
  gap: 10px;
}

.barLabel {
  font-size: 10px;
  font-weight: 700;
  color: var(--text-secondary);
  letter-spacing: 0.06em;
  width: 70px;
  flex-shrink: 0;
}

.barTrack {
  flex: 1;
  height: 4px;
  background: var(--bg-elevated);
  border-radius: 2px;
  overflow: hidden;
}

.barFill {
  height: 100%;
  border-radius: 2px;
  transition: width 0.6s ease;
  opacity: 0.85;
}

.barVal {
  font-size: 11px;
  font-weight: 700;
  min-width: 18px;
  text-align: right;
}

.formulaBox {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-left: 3px solid var(--red);
  border-radius: var(--radius-lg);
  padding: 14px;
}

.formula {
  font-size: 13px;
  color: var(--text-primary);
  margin-bottom: 8px;
  line-height: 1.6;
  font-style: italic;
}

.formulaNote {
  font-size: 11px;
  color: var(--text-muted);
  line-height: 1.7;
}
.timeline {
  display: flex;
  justify-content: space-between;
  margin: 20px 0;
  padding: 10px;
  background: #1a1a1a;
  border-radius: 8px;
}

.step {
  font-size: 10px;
  color: #555;
  position: relative;
}

.step.active {
  color: var(--blue);
  font-weight: bold;
}

.statusDone { color: var(--green); }
.statusPending { color: var(--amber); }